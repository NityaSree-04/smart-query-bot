# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=8080

# AI Configuration
# Option 1: OpenRouter (Recommended for Ideathon - Free models available!)
# Get your key from: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Option 2: OpenAI (Paid)
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENROUTER_BASE_URL=https://api.openai.com/v1
# OPENROUTER_MODEL=gpt-4

# Option 3: Google Gemini via OpenRouter (Free)
# OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=google/gemini-flash-1.5:free

# Database Configuration (choose one or configure multiple)
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_database

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=your_database

# SQLite
SQLITE_PATH=./data.db

# Active Database Type (postgres, mysql, or sqlite)
DB_TYPE=sqlite
